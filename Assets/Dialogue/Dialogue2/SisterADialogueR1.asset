%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 138f6842224072a4182b96a9c9110c3e, type: 3}
  m_Name: SisterADialogueR1
  m_EditorClassIdentifier: 
  lines:
  - text: I see...
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 776495633642d87409ceb71428490f47, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: This is... Not exactly what I expected.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 776495633642d87409ceb71428490f47, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: The office works at night, that's what it said.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 776495633642d87409ceb71428490f47, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Then you're not here by accident.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 776495633642d87409ceb71428490f47, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Good.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: d22b3684ff90e474aa3f81aaf587a86d, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: I don't need you to ask questions anyway.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: d22b3684ff90e474aa3f81aaf587a86d, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Listen. I need you to send a letter.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 912423b8de0bd884aa0b76839bfa29dc, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: It's important.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 56a277fcff2ccf94eaf79fdcf2f84d6e, type: 3}
    uiObjectIDs:
    - Envelope
    objectsInteractable: 1
  - text: I need you to carry it.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 56a277fcff2ccf94eaf79fdcf2f84d6e, type: 3}
    uiObjectIDs:
    - 1
    objectsInteractable: 0
  - text: I know how this looks.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: e9c914ed49cb81145857b7a9a55b507f, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: A pigeon. Night mail. War outside.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: e9c914ed49cb81145857b7a9a55b507f, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: But if you really work here...
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: a28bffe9013377546a43c75dd3a201a3, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Then you know how to deliver
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 912423b8de0bd884aa0b76839bfa29dc, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: And... How do I pay you?
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 41d80a86173804d45912eb3665905731, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Money?
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 912423b8de0bd884aa0b76839bfa29dc, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: Oh... I'm sorry. I didn't think.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 776495633642d87409ceb71428490f47, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: This is all I have.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: 56a277fcff2ccf94eaf79fdcf2f84d6e, type: 3}
    uiObjectIDs:
    - Basmaluta
    objectsInteractable: 1
  - text: It's warm. And clean. If that's alright.
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: d22b3684ff90e474aa3f81aaf587a86d, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  - text: So..? Can you help me?
    voiceClip: {fileID: 0}
    stopPreviousSound: 1
    emotionSprite: {fileID: 21300000, guid: d22b3684ff90e474aa3f81aaf587a86d, type: 3}
    uiObjectIDs: []
    objectsInteractable: 0
  choices:
  - text: Yes "take the letter"
    nextNode: {fileID: 11400000, guid: c3912cbcf7536534ca09d9ee4b65d67b, type: 2}
  - text: No "Decline"
    nextNode: {fileID: 11400000, guid: 9a22ec8a03d4cc14897c4884c1cbcdbe, type: 2}
