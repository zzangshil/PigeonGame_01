%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 138f6842224072a4182b96a9c9110c3e, type: 3}
  m_Name: FirstDialogue
  m_EditorClassIdentifier: 
  lines:
  - text: "\u2026What?"
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: e36f6463ff973d240bb81571713be929, type: 3}
  - text: A pigeon. With a letter.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: fb0a261488cef31468b51fab509e72a1, type: 3}
  - text: 'My sister, huh? '
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 031c2578d0a15ae4fa7822ba5d4bc9ad, type: 3}
  - text: Of course.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 58fd5407f91433a4e85e0f7bd0ef1461, type: 3}
  - text: " Who else would write\u2026 like this. "
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c68132b89faa84242a8341f3a0695cc2, type: 3}
  - text: Come here.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c68132b89faa84242a8341f3a0695cc2, type: 3}
  - text: ' She always thought that if you tried hard enough,'
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 58fd5407f91433a4e85e0f7bd0ef1461, type: 3}
  - text: you could save everyone.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 58fd5407f91433a4e85e0f7bd0ef1461, type: 3}
  - text: ' I told her not to write.'
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c68132b89faa84242a8341f3a0695cc2, type: 3}
  - text: ' I told her it was dangerous.'
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 58fd5407f91433a4e85e0f7bd0ef1461, type: 3}
  - text: ...
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c94edc1a48826664c9c1da4980c98967, type: 3}
  - text: You look tired.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c68132b89faa84242a8341f3a0695cc2, type: 3}
  - text: We all do these days.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 031c2578d0a15ae4fa7822ba5d4bc9ad, type: 3}
  - text: Wait I should write back
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: c68132b89faa84242a8341f3a0695cc2, type: 3}
  - text: "\u2026No. Better not."
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: 58fd5407f91433a4e85e0f7bd0ef1461, type: 3}
  - text: Thank you for bringing it.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: bd4818746295b9d4d92e63a28a159e07, type: 3}
  - text: You can fly now.
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: ce4e98ea61415d14c97b4796b9f9fcf2, type: 3}
  - text: "We\u2019ll see each other again."
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: fb0a261488cef31468b51fab509e72a1, type: 3}
  - text: "If we\u2019re lucky."
    voiceClip: {fileID: 0}
    stopPreviousSound: 0
    emotionSprite: {fileID: 21300000, guid: fb0a261488cef31468b51fab509e72a1, type: 3}
  choices:
  - text: Bye!
    nextNode: {fileID: 0}
